/* Anthropic Claude Official Design System */
/* Base: #1A1A1A, Terracotta: #C97456, Kraft: #D4B896, Manila: #E8DCC8 */

* {
    margin: 0;
    padding: 0;
    border: none;
}

QMainWindow, QWidget {
    background-color: #1A1A1A;
    color: #FFFFFF;
    border: none;
}

QLabel {
    color: #FFFFFF;
    background-color: transparent;
    border: none;
}

#pageTitle {
    font-size: 18px;
    font-weight: 600;
    color: #FFFFFF;
}

#serverNameLabel {
    font-size: 18px;
    font-weight: 700;
    color: #FFFFFF;
}

#serverDetailLabel {
    font-size: 12px;
    color: #B0B0B0;
    font-weight: 400;
}

#configInfoLabel {
    font-size: 11px;
    color: #D4B896;
    margin-top: 4px;
    font-weight: 500;
}

#stateLabel {
    color: #FFFFFF;
}

#serverCard {
    background-color: #242424;
    border: none;
    border-radius: 12px;
}

QPushButton {
    background-color: #2A2A2A;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 10px 18px;
    font-weight: 600;
    font-size: 12px;
    min-height: 40px;
}

QPushButton:hover {
    background-color: #333333;
}

QPushButton:pressed {
    background-color: #1F1F1F;
}

QPushButton:disabled {
    background-color: #1F1F1F;
    color: #666666;
}

#connectButton {
    background-color: #C97456;
    color: #FFFFFF;
    font-weight: 700;
}

#connectButton:hover {
    background-color: #D98566;
}

#connectButton:pressed {
    background-color: #B96446;
}

#connectButton:disabled {
    background-color: #664C39;
    color: #999999;
}

#disconnectButton {
    background-color: #3A3A3A;
    color: #FFFFFF;
}

#disconnectButton:hover {
    background-color: #454545;
}

#disconnectButton:pressed {
    background-color: #2F2F2F;
}

#disconnectButton:disabled {
    background-color: #1F1F1F;
    color: #666666;
}

QLineEdit {
    background-color: #242424;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 8px 10px;
    font-size: 11px;
    selection-background-color: #C97456;
}

QLineEdit:focus {
    background-color: #2A2A2A;
}

QListWidget {
    background-color: #242424;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
}

QListWidget::item {
    padding: 8px;
    border-radius: 3px;
}

QListWidget::item:selected {
    background-color: #C97456;
    color: #FFFFFF;
}

QListWidget::item:hover {
    background-color: #2F2F2F;
}

QGroupBox {
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    margin-top: 8px;
    padding-top: 12px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 4px;
}

QMenuBar {
    background-color: #1A1A1A;
    color: #FFFFFF;
    border: none;
}

QMenuBar::item:selected {
    background-color: #2A2A2A;
    color: #C97456;
}

QMenu {
    background-color: #242424;
    color: #FFFFFF;
    border: none;
}

QMenu::item:selected {
    background-color: #C97456;
    color: #FFFFFF;
}

QTabWidget::pane {
    border: none;
}

QTabBar::tab {
    background-color: #1A1A1A;
    color: #B0B0B0;
    padding: 8px 16px;
    border: none;
    border-radius: 0px;
    font-weight: 500;
}

QTabBar::tab:selected {
    background-color: #C97456;
    color: #FFFFFF;
}

QTabBar::tab:hover {
    background-color: #2A2A2A;
}

QScrollBar {
    background-color: #1A1A1A;
}

QScrollBar:vertical {
    width: 10px;
}

QScrollBar:horizontal {
    height: 10px;
}

QScrollBar::handle:vertical {
    background-color: #3A3A3A;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #454545;
}

QScrollBar::handle:horizontal {
    background-color: #3A3A3A;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #454545;
}

QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical,
QScrollBar::left-arrow:horizontal, QScrollBar::right-arrow:horizontal {
    border: none;
    background: none;
}

QProgressBar {
    background-color: #242424;
    border: none;
    border-radius: 4px;
    color: #FFFFFF;
    text-align: center;
    height: 8px;
    padding: 0px;
}

QProgressBar::chunk {
    background-color: #C97456;
    border-radius: 3px;
}

QStatusBar {
    background-color: #1A1A1A;
    color: #B0B0B0;
    border: none;
    padding: 4px;
}

QCheckBox {
    color: #FFFFFF;
    spacing: 6px;
    font-weight: 500;
    background-color: transparent;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: none;
    border-radius: 3px;
    background-color: #2A2A2A;
}

QCheckBox::indicator:checked {
    background-color: #C97456;
}

QCheckBox::indicator:hover {
    background-color: #333333;
}

QRadioButton {
    color: #FFFFFF;
    spacing: 6px;
    font-weight: 500;
    background-color: transparent;
}

QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border: none;
    border-radius: 8px;
    background-color: #2A2A2A;
}

QRadioButton::indicator:checked {
    background-color: #C97456;
}

QComboBox {
    background-color: #242424;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 6px 8px;
    font-weight: 500;
}

QComboBox:focus {
    background-color: #2A2A2A;
}

QComboBox::drop-down {
    border: none;
    background: transparent;
}

QTextBrowser, QPlainTextEdit {
    background-color: #242424;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 8px;
}

QSpinBox, QDoubleSpinBox {
    background-color: #242424;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 6px;
    font-weight: 500;
}

QSlider::groove:horizontal {
    background-color: #2A2A2A;
    border: none;
    height: 6px;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background-color: #C97456;
    border: none;
    width: 16px;
    margin: -5px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #D98566;
}

QDialog {
    background-color: #1A1A1A;
    border: none;
}

QMessageBox {
    background-color: #1A1A1A;
    border: none;
}

QMessageBox QLabel {
    color: #FFFFFF;
    background-color: transparent;
}

QWidget#navBar {
    background-color: #1A1A1A;
    border: none;
}

QPushButton#navButton {
    background-color: transparent;
    color: #B0B0B0;
    border: none;
    padding: 6px 0;
    font-size: 11px;
}

QPushButton#navButton:checked {
    color: #C97456;
}

QPushButton#navButton:hover {
    color: #FFFFFF;
}
